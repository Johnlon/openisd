#!/usr/bin/env bash
#
# grep_local — a confined, read-only wrapper around GNU grep, locked to THIS project.
#
# Access model (deliberately narrow so `Bash(grep_local:*)` is safe to grant blanket):
#   • Root is the PROJECT ROOT ONLY — computed from this script's own location
#     (<root>/.claude/tools/grep_local/grep_local → three levels up). It is NOT
#     configurable by env var, so the grant cannot be widened at call time.
#   • The tool ALWAYS `cd`s to the project root before searching. Every search
#     therefore runs from, and is scoped to, the project tree.
#   • All path operands MUST be RELATIVE to the project root (an input-format
#     rule — absolute POSIX `/…` and Windows `C:\…` / `C:/…` paths are rejected).
#   • Containment is decided by RESOLVING each path with `realpath -m` (which
#     canonicalizes by following every symlink in every component — verified on
#     this platform against a native symlink — while tolerating a not-yet-
#     existing trailing component). The resolved real path must sit under the
#     project root. We do NOT infer containment from the path's text: a symlink
#     whose name looks in-project but points outside is resolved and rejected;
#     a `..` sequence is resolved, not string-matched. There is no way to read a
#     file outside this project.
#
# It CANNOT:
#   • search any path outside the project root (traversal is resolved & rejected)
#   • read patterns from a file (-f/--file) — that could pull in arbitrary paths
#   • execute anything (grep has no -exec; we reject it explicitly anyway)
#   • use any flag not on the whitelist below
#
# This is a guard-rail that keeps a broad permission grant read-only and
# project-scoped — not a sandbox against a hostile local user.
#
# Usage: basic grep syntax, with RELATIVE paths only, e.g.
#   grep_local -rn "resonate" packages/
#   grep_local -ril --include='*.ts' "toWdr" .
#   grep_local --help
#
set -euo pipefail
[ -z "${MSYSTEM:-}" ] && echo "grep_local: must run in Git Bash on Windows, not WSL or PowerShell" >&2 && exit 1

# Project root = three levels up from this script (never from CWD, never from env).
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd -P)"
ROOT_REAL="$(cd "$SCRIPT_DIR/../../.." && pwd -P)"

usage() {
  cat >&2 <<EOF
grep_local — confined read-only grep, locked to project root:
  $ROOT_REAL

Basic grep syntax. Paths MUST be relative to the project root. Allowed flags:
  -r -R --recursive  -n --line-number  -i --ignore-case
  -l --files-with-matches  -L --files-without-match  -c --count
  -o --only-matching  -v --invert-match  -w --word-regexp  -x --line-regexp
  -E --extended-regexp  -F --fixed-strings  -P --perl-regexp  -e PATTERN
  -A N  -B N  -C N  -m N  --context N
  -h -H -s -a  --color[=WHEN]
  --include=GLOB  --exclude=GLOB  --exclude-dir=GLOB

Rejected (exit 2): -f/--file, -d/--devices, -D, -exec, absolute paths,
paths escaping the root, and anything not on the whitelist.
EOF
}

# Always operate from the project root.
cd "$ROOT_REAL"

# Flags that consume the FOLLOWING argument as their value (space-separated form).
declare -A TAKES_VALUE=(
  [-A]=1 [-B]=1 [-C]=1 [-m]=1 [-e]=1 [--context]=1
  [--include]=1 [--exclude]=1 [--exclude-dir]=1 [--color]=1 [--colour]=1
)

# Whitelisted option tokens (exact, =-form, and known-safe glued short forms).
is_allowed_opt() {
  case "$1" in
    -r|-R|--recursive|-n|--line-number|-i|--ignore-case|\
    -l|--files-with-matches|-L|--files-without-match|-c|--count|\
    -o|--only-matching|-v|--invert-match|-w|--word-regexp|-x|--line-regexp|\
    -E|--extended-regexp|-F|--fixed-strings|-P|--perl-regexp|-e|\
    -A|-B|-C|-m|--context|-h|-H|-s|-a|\
    --color|--colour|--include|--exclude|--exclude-dir) return 0 ;;
    --color=*|--colour=*|--include=*|--exclude=*|--exclude-dir=*|--context=*|-m=*) return 0 ;;
    -[ABCm][0-9]*) return 0 ;;
    -[rRnilLcovwxEFPHhsa]*) [[ "$1" =~ ^-[rRnilLcovwxEFPHhsaABCm]+([0-9]*)$ ]] && return 0 ;;
  esac
  return 1
}

opts=()        # reconstructed option list passed to real grep
pat=""         # the search pattern (bare operand or via -e)
have_pat=0     # 1 once a pattern is known
paths=()       # file/dir operands (must be relative, under root)
saw_e=0        # -e was used → bare operands are all paths

reject() { echo "grep_local: $1" >&2; exit 2; }

# Reject dangerous / non-whitelisted tokens up front.
for a in "$@"; do
  case "$a" in
    -f|--file|--file=*) reject "reading patterns from a file (-f/--file) is not allowed" ;;
    -d|--devices|--devices=*|-D|--binary-files=*) reject "device/binary-mode flags are not allowed" ;;
    -exec|--exec|-exec=*) reject "-exec is not allowed" ;;
  esac
done

if [ "$#" -eq 0 ]; then usage; exit 2; fi
if { [ "$1" = "--help" ] || [ "$1" = "-h" ]; } && [ "$#" -eq 1 ]; then usage; exit 0; fi

while [ "$#" -gt 0 ]; do
  a="$1"; shift
  if [ "$a" = "--" ]; then
    while [ "$#" -gt 0 ]; do paths+=("$1"); shift; done
    break
  fi
  if [[ "$a" == -* && "$a" != "-" ]]; then
    is_allowed_opt "$a" || reject "flag not on the whitelist: $a  (see --help)"
    opts+=("$a")
    if [ "${TAKES_VALUE[$a]:-}" = "1" ]; then
      [ "$#" -gt 0 ] || reject "flag $a expects a value"
      if [ "$a" = "-e" ]; then pat="$1"; have_pat=1; saw_e=1; opts+=("$1")
      else opts+=("$1"); fi
      shift
    fi
    continue
  fi
  if [ "$have_pat" -eq 0 ] && [ "$saw_e" -eq 0 ]; then
    pat="$a"; have_pat=1
  else
    paths+=("$a")
  fi
done

[ "$have_pat" -eq 1 ] || reject "no search pattern given"
[ "${#paths[@]}" -eq 0 ] && paths=(".")

# Path operands: must be RELATIVE, and must resolve to under the project root.
for p in "${paths[@]}"; do
  case "$p" in
    /*)      reject "absolute paths are not allowed, use a path relative to project root: $p" ;;
    [A-Za-z]:[\\/]*) reject "Windows absolute paths are not allowed, use a relative path: $p" ;;
  esac
  rp="$(realpath -m -- "$p")"
  if [ "$rp" != "$ROOT_REAL" ] && [[ "$rp" != "$ROOT_REAL"/* ]]; then
    reject "path escapes the project root ($ROOT_REAL): $p"
  fi
done

# Reconstruct with the pattern via -e (safe even if it starts with '-') and
# '--' before the paths so no filename can be mistaken for an option.
if [ "$saw_e" -eq 1 ]; then
  exec grep "${opts[@]}" -- "${paths[@]}"
else
  exec grep "${opts[@]}" -e "$pat" -- "${paths[@]}"
fi
